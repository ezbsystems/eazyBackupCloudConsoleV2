###############################################################################
# Global default: ignore everything in this tree
###############################################################################
/*

# Keep this file
!.gitignore

# Optional: keep environment + editor config
!/.env
!/.vscode/
!/.vscode/**

###############################################################################
# Top-level app bits we own
###############################################################################

# Our worker services
!/e3-cloudbackup-worker/
!/e3-cloudbackup-worker/**

!/ms365-backup-worker/
!/ms365-backup-worker/**
# Keep compiled worker artifacts out of git (published via fleet storage)
/ms365-backup-worker/bin/
/ms365-backup-worker/bin/**
/ms365-backup-worker/ms365-backup-worker
/ms365-backup-worker/worker

# Our local backup agent
!/e3-backup-agent/
!/e3-backup-agent/**

# Recovery media scripts/docs (track these)
!/recovery/
!/recovery/**

# Keep generated recovery build artifacts out of git
/recovery/**/out/
/recovery/**/work/
/recovery/**/*.iso
/recovery/**/*.img
/recovery/**/*.wim
/recovery/**/*.vhd
/recovery/**/*.vhdx

# Keep local driver payloads out of git (track docs/placeholders only)
/recovery/winpe/drivers/**
!/recovery/winpe/drivers/
!/recovery/winpe/drivers/**/
!/recovery/winpe/drivers/README.md
!/recovery/winpe/drivers/**/.gitkeep

# Our backup script
!/backup_whmcs_db.sh

# DO NOT track installers in this repo
# (client_installer directory stays on disk but is ignored)
/client_installer/
!/client_installer  # allow the dir name to exist but not be tracked
/client_installer/**

# DO NOT track logs in this repo
/logs/
!/logs
/logs/**

###############################################################################
# WHMCS � only track our custom code, ignore WHMCS core
###############################################################################

# Keep the accounts/ tree, but ONLY selectively
!/accounts/

# Ignore everything inside accounts by default...
/accounts/*

# ---------------------- includes/hooks (all ours) ----------------------
!/accounts/includes/
!/accounts/includes/**
!/accounts/includes/hooks/
!/accounts/includes/hooks/**

# ---------------------- crons (only our custom ones) -------------------
!/accounts/crons/
!/accounts/crons/**
# add more custom crons if needed:
# !/accounts/crons/anotherCustomCron.php

# ---------------------- addon modules we own ---------------------------
!/accounts/modules/
!/accounts/modules/addons/

!/accounts/modules/addons/cloudstorage/
!/accounts/modules/addons/cloudstorage/**

!/accounts/modules/addons/cometbilling/
!/accounts/modules/addons/cometbilling/**

!/accounts/modules/addons/eazybackup/
!/accounts/modules/addons/eazybackup/**

!/accounts/modules/addons/hidepermissions/
!/accounts/modules/addons/hidepermissions/**

!/accounts/modules/addons/mspconnect/
!/accounts/modules/addons/mspconnect/**

!/accounts/modules/addons/ms365backup/
!/accounts/modules/addons/ms365backup/**
# Fleet build/publish artifacts stay on disk only
/accounts/modules/addons/ms365backup/storage/worker-releases/**/ms365-backup-worker
/accounts/modules/addons/ms365backup/storage/worker-builds/**

# ---------------------- server modules we own --------------------------
!/accounts/modules/servers/
!/accounts/modules/servers/comet/
!/accounts/modules/servers/comet/**

# ---------------------- gateway modules we own -------------------------
!/accounts/modules/gateways/
!/accounts/modules/gateways/stripe/
!/accounts/modules/gateways/stripe/**

# ---------------------- our custom client area template ----------------
!/accounts/templates/
/accounts/templates/*
!/accounts/templates/eazyBackup/
!/accounts/templates/eazyBackup/**

# Extra safety: never track these log fragments anywhere
*.log.filepart

# ---------------------- test/coverage artifacts ----------------------
# PHPUnit cache + coverage reports for the eazyBackup addon
/accounts/modules/addons/eazybackup/.phpunit.cache/
/accounts/modules/addons/eazybackup/.phpunit.cache/**
/accounts/modules/addons/eazybackup/tests/_coverage/
/accounts/modules/addons/eazybackup/tests/_coverage/**
